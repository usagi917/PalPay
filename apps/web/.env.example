# RPC URL for the target testnet
# Examples:
# - Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# - Base Sepolia: https://sepolia.base.org
NEXT_PUBLIC_RPC_URL=

# Supported chain IDs:
# - Sepolia: 11155111
# - Base Sepolia: 84532
NEXT_PUBLIC_CHAIN_ID=84532

# JPYC deployment on the selected testnet
NEXT_PUBLIC_JPYC_FACTORY_ADDRESS=
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS=

# USDC deployment on the selected testnet
NEXT_PUBLIC_USDC_FACTORY_ADDRESS=
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=

# Optional: Block explorer base URL for transaction links
# Examples:
# - Sepolia: https://sepolia.etherscan.io/tx/
# - Base Sepolia: https://sepolia.basescan.org/tx/
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=

# XMTP chat (optional)
NEXT_PUBLIC_XMTP_ENV=dev
