# RPC URL for the target network
# Examples:
# - Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# - Base Sepolia: https://sepolia.base.org
# - Polygon Amoy: https://rpc-amoy.polygon.technology
NEXT_PUBLIC_RPC_URL=

# Chain ID
# - Sepolia: 11155111
# - Base Sepolia: 84532
# - Polygon Amoy: 80002
NEXT_PUBLIC_CHAIN_ID=84532

# Deployed contract addresses
# v2: Factory address (required)
NEXT_PUBLIC_FACTORY_ADDRESS=
# ERC20 token address
NEXT_PUBLIC_TOKEN_ADDRESS=

# Optional: Block explorer base URL for transaction links
# Examples:
# - Sepolia: https://sepolia.etherscan.io/tx/
# - Base Sepolia: https://sepolia.basescan.org/tx/
# - Polygon Amoy: https://amoy.polygonscan.com/tx/
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=

# Google Cloud (Vertex AI) - required for AI Agent
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# XMTP (optional)
NEXT_PUBLIC_XMTP_ENV=dev
