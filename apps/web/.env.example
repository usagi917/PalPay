# =============================================================================
# REQUIRED — set these for ALL chains. Do NOT keep stale per-chain defaults.
# =============================================================================

# RPC URL for the target chain used by the web app
NEXT_PUBLIC_RPC_URL=

# Supported chain IDs (must match the addresses below):
# - Sepolia: 11155111
# - Base Sepolia: 84532
# - Polygon Amoy: 80002
# - Polygon mainnet: 137  (Base Account email/Passkey login is intended for this chain)
NEXT_PUBLIC_CHAIN_ID=

# JPYC deployment for the selected chain. MUST match NEXT_PUBLIC_CHAIN_ID.
NEXT_PUBLIC_JPYC_FACTORY_ADDRESS=
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS=

# USDC deployment for the selected chain. MUST match NEXT_PUBLIC_CHAIN_ID.
NEXT_PUBLIC_USDC_FACTORY_ADDRESS=
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=

# Block explorer transaction base URL. MUST match NEXT_PUBLIC_CHAIN_ID.
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=

# WalletConnect Cloud/Reown Project ID. Required for WalletConnect QR/mobile wallet options.
# Get one from https://dashboard.walletconnect.com or https://dashboard.reown.com.
# Configure an origin allowlist for deployed domains before production use.
# When omitted, the app falls back to injected wallets and Base Account.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# XMTP chat (optional)
NEXT_PUBLIC_XMTP_ENV=dev

# =============================================================================
# Per-chain reference values. Pick ONE block, copy it above, then edit.
# Mixing values from different blocks will silently corrupt token identity,
# decimals, balances, and explorer links — runtime guards in config.ts will
# refuse to start when chain id and token addresses do not match.
# =============================================================================

# --- Sepolia (chain 11155111) ----------------------------------------------
# NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# NEXT_PUBLIC_CHAIN_ID=11155111
# NEXT_PUBLIC_JPYC_TOKEN_ADDRESS=0x431D5dfF03120AFA4bDf332c61A6e1766eF37BDB
# NEXT_PUBLIC_USDC_TOKEN_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=https://sepolia.etherscan.io/tx/

# --- Base Sepolia (chain 84532) --------------------------------------------
# NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
# NEXT_PUBLIC_CHAIN_ID=84532
# NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=https://sepolia.basescan.org/tx/

# --- Polygon Amoy (chain 80002) --------------------------------------------
# NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology
# NEXT_PUBLIC_CHAIN_ID=80002
# NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=https://amoy.polygonscan.com/tx/

# --- Polygon mainnet (chain 137) -------------------------------------------
# NEXT_PUBLIC_RPC_URL=https://polygon-rpc.com
# NEXT_PUBLIC_CHAIN_ID=137
# NEXT_PUBLIC_JPYC_TOKEN_ADDRESS=<set the real Polygon JPYC v2 address>
# NEXT_PUBLIC_USDC_TOKEN_ADDRESS=<set the real Polygon USDC (native) or USDC.e address>
# NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=https://polygonscan.com/tx/

# Deploy-time variables such as PRIVATE_KEY, TESTNET_RPC_URL, TOKEN_ADDRESS,
# JPYC_TOKEN_ADDRESS, USDC_TOKEN_ADDRESS, and BASE_URI are used by Foundry scripts.
# Do not put PRIVATE_KEY in this frontend env file.
