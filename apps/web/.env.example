# RPC URL for the target testnet used by the web app
# Examples:
# - Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# - Base Sepolia: https://sepolia.base.org
# - Polygon Amoy: https://rpc-amoy.polygon.technology
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Supported chain IDs:
# - Sepolia: 11155111
# - Base Sepolia: 84532
# - Polygon Amoy: 80002
NEXT_PUBLIC_CHAIN_ID=11155111

# JPYC deployment on the selected testnet.
# Set NEXT_PUBLIC_JPYC_FACTORY_ADDRESS after deploying the JPYC ListingFactoryV6.
NEXT_PUBLIC_JPYC_FACTORY_ADDRESS=
NEXT_PUBLIC_JPYC_TOKEN_ADDRESS=0x431D5dfF03120AFA4bDf332c61A6e1766eF37BDB

# USDC deployment on the selected testnet.
# Set NEXT_PUBLIC_USDC_FACTORY_ADDRESS after deploying the USDC ListingFactoryV6.
NEXT_PUBLIC_USDC_FACTORY_ADDRESS=
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Optional: Block explorer base URL for transaction links
# Examples:
# - Sepolia: https://sepolia.etherscan.io/tx/
# - Base Sepolia: https://sepolia.basescan.org/tx/
# - Polygon Amoy: https://amoy.polygonscan.com/tx/
NEXT_PUBLIC_BLOCK_EXPLORER_TX_BASE=https://sepolia.etherscan.io/tx/

# XMTP chat (optional)
NEXT_PUBLIC_XMTP_ENV=dev

# Deploy-time variables such as PRIVATE_KEY, TESTNET_RPC_URL, TOKEN_ADDRESS,
# JPYC_TOKEN_ADDRESS, USDC_TOKEN_ADDRESS, and BASE_URI are used by Foundry scripts.
# Do not put PRIVATE_KEY in this frontend env file.
